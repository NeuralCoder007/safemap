# Server-side map API secret (set in Vercel Project -> Settings -> Environment Variables).
# Enable in Google Cloud: Geocoding API, Places API (Autocomplete + Place Details), Static Maps API.
MAP_API_KEY=

# Vercel KV — created in Vercel → Storage → Create Database (KV).
# For local dev: link the project (`npx vercel link`) then `npx vercel env pull .env.local`
KV_REST_API_URL=
KV_REST_API_TOKEN=
